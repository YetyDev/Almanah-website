    <style>
      .policy-hero-layout {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
        text-align: left;
        padding: 2rem 0;
        position: relative;
        z-index: 3;
      }
      .trust-card-glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--border-radius);
        padding: 2.5rem;
        width: 100%;
        max-width: 320px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        position: relative;
        z-index: 2;
        transform: perspective(1000px) rotateY(-10deg) rotateX(10deg);
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease, border-color 0.5s ease;
      }
      .trust-card-glass:hover {
        transform: perspective(1000px) rotateY(-2deg) rotateX(2deg) translateY(-5px) !important;
        box-shadow: 0 25px 50px rgba(76, 27, 111, 0.25) !important;
        border-color: rgba(255, 255, 255, 0.18) !important;
      }
      @keyframes badgeDotPulseSecondary {
        0% {
          transform: scale(1);
          opacity: 1;
          box-shadow: 0 0 0 0 rgba(209, 46, 123, 0.7);
        }
        70% {
          transform: scale(1.2);
          opacity: 0.6;
          box-shadow: 0 0 0 6px rgba(209, 46, 123, 0);
        }
        100% {
          transform: scale(1);
          opacity: 1;
          box-shadow: 0 0 0 0 rgba(209, 46, 123, 0);
        }
      }
      @media (max-width: 991px) {
        .policy-hero-layout {
          flex-direction: column;
          text-align: center !important;
          gap: 3rem !important;
          padding: 1rem 0;
        }
        .policy-hero-text h1 {
          text-align: center !important;
        }
        .policy-hero-text .about-hero-description {
          text-align: center !important;
          margin: 0 auto !important;
        }
        .trust-card-glass {
          transform: none !important;
        }
      }
    </style>

