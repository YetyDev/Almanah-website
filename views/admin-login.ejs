<%- include('partials/head', { title: 'Admin Sign In' }) %>

<style>
  .login-page-body {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #140720;
    background-image: radial-gradient(circle at 20% 30%, rgba(76, 27, 111, 0.45) 0%, transparent 50%),
                      radial-gradient(circle at 80% 70%, rgba(209, 46, 123, 0.3) 0%, transparent 50%);
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .login-glow-1 {
    position: absolute;
    width: 300px;
    height: 300px;
    background: var(--primary);
    filter: blur(120px);
    border-radius: 50%;
    top: -50px;
    left: -50px;
    opacity: 0.3;
    pointer-events: none;
  }

  .login-glow-2 {
    position: absolute;
    width: 300px;
    height: 300px;
    background: var(--secondary);
    filter: blur(120px);
    border-radius: 50%;
    bottom: -50px;
    right: -50px;
    opacity: 0.2;
    pointer-events: none;
  }

  .login-container {
    width: 100%;
    max-width: 440px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--border-radius-lg);
    padding: 3.5rem 2.5rem;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.45);
    position: relative;
    z-index: 10;
    text-align: center;
  }

  .login-header {
    margin-bottom: 2.5rem;
  }

  .login-logo {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    margin-bottom: 1.25rem;
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    border: 1.5px solid rgba(255, 255, 255, 0.1);
  }

  .login-header h1 {
    font-size: 1.8rem;
    font-family: var(--font-title);
    color: #FFFFFF;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .login-header p {
    color: #B5A1C0;
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  /* Form controls */
  .login-form .form-group-modern {
    margin-bottom: 1.75rem;
    text-align: left;
  }

  .login-form .form-control-modern {
    background-color: rgba(255, 255, 255, 0.04) !important;
    border-color: rgba(255, 255, 255, 0.12) !important;
    color: #FFFFFF !important;
  }

  .login-form .form-control-modern:focus {
    border-color: var(--secondary) !important;
    box-shadow: 0 0 10px rgba(209, 46, 123, 0.2) !important;
  }

  .login-form .form-label-modern {
    color: rgba(255, 255, 255, 0.5) !important;
  }

  .login-form .form-control-modern:focus ~ .form-label-modern,
  .login-form .form-control-modern:not(:placeholder-shown) ~ .form-label-modern {
    color: var(--secondary) !important;
  }

  .login-btn {
    width: 100%;
    padding: 0.9rem !important;
    font-size: 0.95rem !important;
    font-weight: 600 !important;
    margin-top: 1rem;
  }

  /* Error Alert */
  .login-error {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #FCA5A5;
    padding: 0.75rem 1rem;
    border-radius: var(--border-radius);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .login-error svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .back-to-home {
    position: absolute;
    top: 2rem;
    left: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #B5A1C0;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: var(--transition);
    z-index: 10;
  }

  .back-to-home:hover {
    color: #FFFFFF;
    transform: translateX(-4px);
  }

  .back-to-home svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
</style>

<div class="login-page-body">
  <div class="login-glow-1"></div>
  <div class="login-glow-2"></div>

  <a href="/" class="back-to-home">
    <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
    Back to Website
  </a>

  <div class="login-container">
    <div class="login-header">
      <img src="/logo.jpeg" alt="Almanah Logo" class="login-logo">
      <h1>Admin Portal</h1>
      <p>Sign in to access your dashboard control panel</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="login-error">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        <span><%= error %></span>
      </div>
    <% } %>

    <form class="login-form" action="/admin/login" method="POST">
      <div class="form-group-modern">
        <input type="text" name="username" class="form-control-modern" placeholder=" " required autofocus>
        <label class="form-label-modern">Username</label>
      </div>

      <div class="form-group-modern">
        <input type="password" name="password" class="form-control-modern" placeholder=" " required>
        <label class="form-label-modern">Password</label>
      </div>

      <button type="submit" class="btn btn-primary login-btn">Sign In</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
