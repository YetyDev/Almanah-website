<!-- SCRIPTS FOR INTERACTIVE HOMEPAGE -->
<script>
  document.addEventListener('DOMContentLoaded', () => {

    // 1. DONATION PROGRAM TABS & TIER SELECTOR & VALUE HANDLER
    const tabBtns = document.querySelectorAll('.donation-tab-btn');
    const tierBtns = document.querySelectorAll('.tier-btn');
    const customAmountInput = document.getElementById('custom-amount');
    let selectedDonation = 25; // Default
    let selectedProgram = 'general'; // Default program
    let selectedCurrency = 'USD'; // Default currency
    let selectedSymbol = '$'; // Default symbol

    // Currency Selector handler
    const currencyBtns = document.querySelectorAll('.currency-btn');
    const currencySymbolSpan = document.querySelector('.custom-amount-container .currency-symbol');

    currencyBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        currencyBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedCurrency = btn.getAttribute('data-currency');
        selectedSymbol = btn.getAttribute('data-symbol');

        // Update predefined tier button text values
        tierBtns.forEach(tBtn => {
          const val = tBtn.getAttribute('data-val');
          tBtn.textContent = selectedSymbol + val;
        });

        // Update custom amount symbol
        if (currencySymbolSpan) {
          currencySymbolSpan.textContent = selectedSymbol;
        }
      });
    });

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedProgram = btn.getAttribute('data-program');
      });
    });

    tierBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tierBtns.forEach(b => b.classList.remove('active'));
        customAmountInput.value = '';
        btn.classList.add('active');
        selectedDonation = parseInt(btn.getAttribute('data-val'));
      });
    });

    customAmountInput.addEventListener('input', () => {
      tierBtns.forEach(b => b.classList.remove('active'));
      selectedDonation = customAmountInput.value ? parseFloat(customAmountInput.value) : 0;
    });

    const donationForm = document.getElementById('donation-form');
    if (donationForm) {
      donationForm.addEventListener('submit', (e) => {
        e.preventDefault();
        if (selectedDonation <= 0) {
          alert('Please select or input a donation amount.');
          return;
        }
        
        fetch('/api/donate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ amount: selectedDonation, program: selectedProgram, currency: selectedCurrency })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            window.showSuccessAlert(`Secure Donation of ${selectedSymbol}${selectedDonation} (${selectedCurrency}) for the ${selectedProgram.toUpperCase()} fund initiated! Thank you for your support.`);
            donationForm.reset();
            tierBtns.forEach(b => b.classList.remove('active'));
            // Reset predefined tiers with current symbol
            tierBtns.forEach(tBtn => {
              const val = tBtn.getAttribute('data-val');
              tBtn.textContent = selectedSymbol + val;
            });
            document.querySelector('.tier-btn[data-val="25"]').classList.add('active');
            selectedDonation = 25;
          } else {
            alert(data.error || 'Something went wrong processing your donation.');
          }
        })
        .catch(err => {
          console.error('Donation submission error:', err);
          alert('An error occurred. Please try again.');
        });
      });
    }

    // Scripts for success story carousel, FAQ accordion, and contact form submission 
    // have been relocated to their respective subpages (Impact & Contact Us) to optimize homepage performance.

    // 5. SCROLL-REVEAL INTERSECTION OBSERVER
    const revealElements = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && revealElements.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, {
        threshold: 0.08,
        rootMargin: '0px 0px -40px 0px'
      });

      revealElements.forEach(el => observer.observe(el));
    } else {
      // Fallback: make everything visible if browser doesn't support IntersectionObserver
      revealElements.forEach(el => el.classList.add('active'));
    }

  });
</script>

