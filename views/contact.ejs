<%- include('partials/head', { title: 'Contact Us' }) %>
<%- include('partials/header') %>

<!-- CONTACT HERO SECTION -->
<section class="about-hero contact-hero">
  <div class="about-hero-glow-left"></div>
  <div class="container">
    <div class="about-hero-badge reveal fade-in-up">
      <span class="badge-dot"></span>
      Get in Touch
    </div>
    <h1 class="reveal fade-in-up delay-1">Contact <span>Us</span></h1>
    <p class="about-hero-description reveal fade-in-up delay-2">
      Reach out to nominate a beneficiary, volunteer for our next outreach campaign, or partner with us.
    </p>
  </div>
</section>

<!-- CONTACT SECTION & FORM -->
<section class="contact-section">
  <div class="container">
    <div class="contact-section-grid">
      <!-- Contact Info Column -->
      <div class="contact-info-panel reveal fade-in-left">
        <div class="contact-info-cards">
          <!-- Email -->
          <div class="contact-info-card">
            <div class="contact-info-card-icon">
              <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" /></svg>
            </div>
            <div class="contact-info-card-content">
              <strong>Email Address</strong>
              <a href="mailto:info@almanahcarefoundation.ng">info@almanahcarefoundation.ng</a>
            </div>
          </div>

          <!-- Location -->
          <div class="contact-info-card">
            <div class="contact-info-card-icon">
              <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
            </div>
            <div class="contact-info-card-content">
              <strong>Our Location</strong>
              <span>Nigeria — serving communities nationwide</span>
            </div>
          </div>

          <!-- Response Time -->
          <div class="contact-info-card">
            <div class="contact-info-card-icon">
              <svg viewBox="0 0 24 24"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z" /></svg>
            </div>
            <div class="contact-info-card-content">
              <strong>Response Time</strong>
              <span>Within 5–7 business days</span>
            </div>
          </div>
        </div>

        <div class="contact-social-row" style="justify-content: center; display: flex; gap: 1rem; margin-top: 2rem;">
          <a href="#" class="social-link" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2m13 2h-2.5A3.5 3.5 0 0 0 12 8.5V11h-2v3h2v7h3v-7h3v-3h-3V9a1 1 0 0 1 1-1h2V5z"/></svg>
          </a>
          <a href="#" class="social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.8 2a3.8 3.8 0 0 0-3.8 3.8v8.4c0 2.1 1.7 3.8 3.8 3.8h8.4c2.1 0 3.8-1.7 3.8-3.8V7.8c0-2.1-1.7-3.8-3.8-3.8H7m8.5 2.1c.5 0 .9.4.9.9s-.4.9-.9.9-.9-.4-.9-.9.4-.9.9-.9M12 6.5a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11m0 2a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7z"/></svg>
          </a>
          <a href="#" class="social-link" aria-label="Twitter">
            <svg viewBox="0 0 24 24"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.48.75 2.78 1.9 3.55-.7 0-1.35-.2-1.93-.53v.05c0 2.05 1.46 3.76 3.4 4.15-.36.1-.73.15-1.12.15-.27 0-.54-.03-.8-.08.54 1.68 2.1 2.9 3.95 2.94-1.44 1.13-3.26 1.8-5.23 1.8-.34 0-.67-.02-1-.06C2.62 19.39 4.8 20 7.14 20c7.81 0 12.08-6.47 12.08-12.08 0-.18 0-.37-.01-.55.83-.6 1.54-1.35 2.11-2.2-.76.34-1.58.57-2.44.67.87-.52 1.54-1.35 1.85-2.34z"/></svg>
          </a>
        </div>
      </div>

      <!-- Contact Form Column -->
      <div class="contact-card modern-form reveal fade-in-right">
        <h3>Send Us a Message</h3>
        <p>Send a message to nominate a beneficiary, express interest in volunteering, or ask a question.</p>

        <form class="contact-form" id="outreach-contact-form">
          <div class="form-group-modern">
            <input type="text" class="form-control-modern" placeholder=" " required id="form-name">
            <label class="form-label-modern">Full Name</label>
          </div>
          <div class="form-group-modern">
            <input type="email" class="form-control-modern" placeholder=" " required id="form-email">
            <label class="form-label-modern">Email Address</label>
          </div>
          <div class="form-group-modern">
            <input type="tel" class="form-control-modern" placeholder=" " id="form-phone">
            <label class="form-label-modern">Phone Number</label>
          </div>
          <div class="form-group-modern">
            <textarea class="form-control-modern" rows="4" placeholder=" " required id="form-message"></textarea>
            <label class="form-label-modern">How can we help you? (e.g. Volunteer, Partner)</label>
          </div>
          <button type="submit" class="btn btn-primary btn-submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FAQ SECTION -->
<section class="faq-section" id="faq">
  <div class="container faq-grid">
    <div class="faq-header-column reveal fade-in-left">
      <span class="faq-tagline">Got Questions?</span>
      <h2 class="faq-heading">Frequently asked<br>questions</h2>
      
      <div class="faq-cta-card">
        <h3>Still have questions?</h3>
        <p>Can't find the answer you're looking for? Send us an email and our team will get back to you as soon as possible.</p>
        <a href="mailto:info@almanahcarefoundation.ng" class="btn btn-primary faq-email-btn">Send email</a>
      </div>
    </div>

    <div class="faq-list reveal fade-in-right">
      <div class="faq-item active">
        <button class="faq-question">
          <h4>How are foundation donations allocated?</h4>
          <span class="faq-icon-box">
            <svg viewBox="0 0 24 24"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z" /></svg>
          </span>
        </button>
        <div class="faq-answer" style="max-height: 200px;">
          <p>
            100% of community-sourced donations go directly into operational programs, including purchasing tools, scholarship funds, food distribution, and renting vocational equipment. Operational overheads are sponsored by founding members and corporate partners.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          <h4>Can I volunteer if I reside outside the local community?</h4>
          <span class="faq-icon-box">
            <svg viewBox="0 0 24 24"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z" /></svg>
          </span>
        </button>
        <div class="faq-answer">
          <p>
            Yes! We have several virtual volunteering pathways, including remote career mentorship, digital literacy material creation, fundraising organization, and administrative advocacy support. Please submit the volunteer form, and we'll match you.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          <h4>How are widows selected for the empowerment grants?</h4>
          <span class="faq-icon-box">
            <svg viewBox="0 0 24 24"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z" /></svg>
          </span>
        </button>
        <div class="faq-answer">
          <p>
            We collaborate with local community leaders, religious associations, and neighborhood assemblies to identify vulnerable households. Candidate selections are evaluated based on family dependency, income metrics, and willingness to participate in the training programs.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          <h4>How can I nominate a beneficiary for the program?</h4>
          <span class="faq-icon-box">
            <svg viewBox="0 0 24 24"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z" /></svg>
          </span>
        </button>
        <div class="faq-answer">
          <p>
            You can nominate a widow, young woman, or child by filling out our contact form below or sending an email to info@almanahcarefoundation.ng. Our team will review the nomination and follow up within 5–7 business days.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          <h4>Is my donation tax-deductible?</h4>
          <span class="faq-icon-box">
            <svg viewBox="0 0 24 24"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z" /></svg>
          </span>
        </button>
        <div class="faq-answer">
          <p>
            Yes. Almanah Care and Love Outreach Foundation is a registered nonprofit organization. All donations are fully tax-deductible, and a donation receipt will be issued to you upon request for your records.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. FAQ ACCORDION
    const faqQuestions = document.querySelectorAll('.faq-question');
    faqQuestions.forEach(btn => {
      btn.addEventListener('click', () => {
        const faqItem = btn.parentElement;
        const answer = faqItem.querySelector('.faq-answer');
        const isActive = faqItem.classList.contains('active');

        document.querySelectorAll('.faq-item').forEach(item => {
          item.classList.remove('active');
          item.querySelector('.faq-answer').style.maxHeight = '0';
        });

        if (!isActive) {
          faqItem.classList.add('active');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });

    // 2. CONTACT FORM SUBMISSION
    const contactForm = document.getElementById('outreach-contact-form');
    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('form-name').value;
        const email = document.getElementById('form-email').value;
        const phone = document.getElementById('form-phone').value;
        const message = document.getElementById('form-message').value;

        fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, email, phone, message })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            window.showSuccessAlert(`Thank you, ${name}! Your outreach message has been sent successfully.`);
            contactForm.reset();
          } else {
            alert(data.error || 'Something went wrong submitting your form.');
          }
        })
        .catch(err => {
          console.error('Contact form submission error:', err);
          alert('An error occurred. Please try again.');
        });
      });
    }

    // 3. Scroll-reveal intersection observer
    const revealElements = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && revealElements.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, {
        threshold: 0.08,
        rootMargin: '0px 0px -40px 0px'
      });

      revealElements.forEach(el => observer.observe(el));
    } else {
      revealElements.forEach(el => el.classList.add('active'));
    }
  });
</script>

<%- include('partials/footer') %>
