<%- include('partials/head', { title: 'Events & Outreach' }) %>
  <%- include('partials/header') %>

    <!-- EVENTS HERO SECTION -->
    <section class="about-hero events-hero">
      <div class="about-hero-glow-left"></div>
      <div class="container">
        <div class="about-hero-badge reveal fade-in-up">
          <span class="badge-dot"></span>
          Active Outreach
        </div>
        <h1 class="reveal fade-in-up delay-1">Events & <span>Campaigns</span></h1>
        <p class="about-hero-description reveal fade-in-up delay-2">
          Join our upcoming campaigns, volunteer for rural outreach, or see the legacy of our completed projects.
        </p>
      </div>
    </section>

    <!-- UPCOMING EVENTS Section -->
    <section class="events-section">
      <div class="container">
        <div class="section-header reveal fade-in-up">
          <h2>Upcoming Campaigns</h2>
          <p>Be a part of our next direct interventions. We are actively seeking volunteers and sponsors.</p>
        </div>

        <div class="events-grid">
          <!-- Event 1 -->
          <div class="event-card reveal fade-in-up delay-1">
            <div class="event-date-badge">
              <span class="day">18</span>
              <span class="month">Aug</span>
            </div>
            <div class="event-card-content">
              <div class="event-meta-info">
                <span class="event-tag badge-violet">Summit</span>
                <span class="event-location">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                  </svg>
                  Lagos Centre, Nigeria
                </span>
              </div>
              <h3>Annual Widow Empowerment Summit 2026</h3>
              <p>
                Our flagship program celebrating the graduation of 200 widows from our vocational cycles. We will
                distribute microfinance grants and startup assets (sewing machines, agricultural starters).
              </p>
              <div class="event-footer-action">
                <a href="/contact" class="btn btn-secondary btn-sm">RSVP or Volunteer</a>
              </div>
            </div>
          </div>

          <!-- Event 2 -->
          <div class="event-card reveal fade-in-up delay-2">
            <div class="event-date-badge">
              <span class="day">05</span>
              <span class="month">Sep</span>
            </div>
            <div class="event-card-content">
              <div class="event-meta-info">
                <span class="event-tag badge-magenta">Education</span>
                <span class="event-location">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                  </svg>
                  Ondo State Outreach
                </span>
              </div>
              <h3>Back to School Kit Drive 2026</h3>
              <p>
                Help us package and distribute educational support kits containing backpacks, notebooks, drawing
                instruments, and school uniforms for 500+ primary school orphans.
              </p>
              <div class="event-footer-action">
                <a href="/contact" class="btn btn-secondary btn-sm">RSVP or Volunteer</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PAST EVENTS Section -->
    <section class="past-events-section">
      <div class="container">
        <div class="section-header reveal fade-in-up">
          <h2>Our Completed Projects</h2>
          <p>Look back at the communities transformed through your continuous support and volunteering.</p>
        </div>

        <div class="past-events-timeline">
          <!-- Item 1 -->
          <div class="past-timeline-item left-card reveal fade-in-left">
            <div class="past-timeline-card-wrapper">
              <div class="past-timeline-meta">
                <span class="past-date">December 2025</span>
                <span class="past-community">Epe Community</span>
              </div>
              <div class="past-timeline-card">
                <h3>Rural Health & Free Medical Camp</h3>
                <p>
                  Provided free health checks, dental examinations, diabetes screenings, and distributed basic
                  prescriptions to over 400 widows, elderly community members, and children.
                </p>
                <span class="past-tag-micro">Completed Impact</span>
              </div>
            </div>
            <div class="past-timeline-image-wrapper">
              <div class="past-timeline-image-inner">
                <img src="/images/image 3.jpg" alt="Rural Health & Free Medical Camp">
              </div>
            </div>
            <div class="past-timeline-dot"></div>
          </div>

          <!-- Item 2 -->
          <div class="past-timeline-item right-card reveal fade-in-right">
            <div class="past-timeline-image-wrapper">
              <div class="past-timeline-image-inner">
                <img src="/images/image 4.jpg" alt="Food Security Outreach">
              </div>
            </div>
            <div class="past-timeline-card-wrapper">
              <div class="past-timeline-meta">
                <span class="past-date">June 2025</span>
                <span class="past-community">Ikorodu Outpost</span>
              </div>
              <div class="past-timeline-card">
                <h3>Food Security & Blanket Relief Outreach</h3>
                <p>
                  Distributed emergency food supplies (rice, dry cereals, vegetable oils) and warm wool blankets to 300+
                  widow-headed households to offset inflation impacts.
                </p>
                <span class="past-tag-micro">Completed Impact</span>
              </div>
            </div>
            <div class="past-timeline-dot"></div>
          </div>

          <!-- Item 3 -->
          <div class="past-timeline-item left-card reveal fade-in-left">
            <div class="past-timeline-card-wrapper">
              <div class="past-timeline-meta">
                <span class="past-date">April 2025</span>
                <span class="past-community">Osun Regional Centre</span>
              </div>
              <div class="past-timeline-card">
                <h3>Widowhood legal Clinic & Rights Advocacy</h3>
                <p>
                  Organized a forum in partnership with regional civil rights lawyers to educate widows on claim
                  submissions, land properties inheritance, and legal defense channels.
                </p>
                <span class="past-tag-micro">Completed Impact</span>
              </div>
            </div>
            <div class="past-timeline-image-wrapper">
              <div class="past-timeline-image-inner">
                <img src="/images/image 2.webp" alt="Widowhood Legal Clinic">
              </div>
            </div>
            <div class="past-timeline-dot"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- GET NOTIFIED CARD -->
    <section class="events-subscribe-section reveal scale-in">
      <div class="container">
        <div class="events-notify-card">
          <div class="notify-card-content">
            <h2>Stay Updated on Future Outreach Events</h2>
            <p>Subscribe to our calendar notifications and receive volunteering schedules directly in your email.</p>
          </div>
          <div class="notify-card-action">
            <form class="events-notify-form" id="newsletter-subscription-form">
              <input type="email" placeholder="Your Email Address" required class="newsletter-input"
                id="newsletter-email">
              <button type="submit" class="btn btn-secondary">Notify Me</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Scroll-reveal intersection observer
        const revealElements = document.querySelectorAll('.reveal');
        if ('IntersectionObserver' in window && revealElements.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('active');
              }
            });
          }, {
            threshold: 0.08,
            rootMargin: '0px 0px -40px 0px'
          });

          revealElements.forEach(el => observer.observe(el));
        } else {
          revealElements.forEach(el => el.classList.add('active'));
        }
      });
    </script>

    <%- include('partials/footer') %>