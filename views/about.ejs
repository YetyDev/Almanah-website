<%- include('partials/head', { title: 'About Us' }) %>
<%- include('partials/header') %>

<!-- ABOUT HERO SECTION -->
<section class="about-hero">
  <div class="about-hero-glow-left"></div>
  <div class="container">
    <div class="about-hero-badge reveal fade-in-up">
      <span class="badge-dot"></span>
      Who We Are
    </div>
    <h1 class="reveal fade-in-up delay-1">About <span>Almanah</span></h1>
    <p class="about-hero-description reveal fade-in-up delay-2">
      We are a registered nonprofit organization dedicated to restoring hope, fostering resilience, and establishing self-reliance for vulnerable widows, young women, and children.
    </p>
  </div>
</section>


<!-- MISSION & VISION SECTION -->
<section class="mission-vision">
  <div class="container">
    <div class="mission-vision-grid">
      <!-- Mission -->
      <div class="mv-card mission">
        <div class="mv-icon-box">
