PUBLIC_BASE_URL=https://almanahcarefoundation.org

# Google Sheets backend. Leave both unset for local development and the app
# will store data in JSON files under data/ instead.
# The ID is the long string in the spreadsheet URL between /d/ and /edit.
SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# Paste the service account key file contents as one line (raw or base64 JSON).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# Paystack handles NGN donations.
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flutterwave handles USD, GBP, and EUR donations.
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxxxxxxxxxxxxxxxxxxxxxxx-x
FLUTTERWAVE_WEBHOOK_HASH=your-flutterwave-secret-hash

# Replace the current hard-coded admin login before production launch.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-before-launch
